<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/setting_toolbar"
        style="@style/Widget.Venus.Toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:title="设置"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/setting_toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_sm">

            <!-- Section: Sign-in Settings -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="签到设置"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/daily_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="米游币签到"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/game_daily_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="游戏签到"
                app:initialExpanded="false" />

            <!-- Section: Config -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="配置"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/config_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="配置信息"
                app:initialExpanded="false" />

            <!-- Section: App -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="应用"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/update_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="更新"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/cache_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="缓存"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/theme_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="主题"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/background_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="背景"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/notification_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="通知"
                app:initialExpanded="false" />

            <!-- Section: Other -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="其他"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/skland_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="森空岛签到"
                app:initialExpanded="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/image_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="查看米游社榜单图"
                app:icon="@drawable/ic_link_url" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/about_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardTitle="关于"
                app:initialExpanded="false" />

            <View
                android:id="@+id/bottom_padding_view"
                android:layout_width="match_parent"
                android:layout_height="96dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
