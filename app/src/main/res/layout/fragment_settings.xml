<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/setting_toolbar"
        style="@style/Widget.Venus.Toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:title="@string/settings_title"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/setting_toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingTop="@dimen/spacing_sm">

            <!-- Section: Sign-in Settings -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/section_sign_in_settings"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/daily_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="@string/miyoushe_coin_sign_in"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/game_daily_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/game_sign_in"
                app:initialExpanded="false" />

            <!-- Section: Config -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/section_config"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/server_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/server_type"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/config_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/config_info"
                app:initialExpanded="false" />

            <!-- Section: App -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/section_app"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/update_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="@string/update"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/cache_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/cache"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/language_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/language"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/theme_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/theme"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/background_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/background"
                app:initialExpanded="false" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/notification_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardTitle="@string/background_running"
                app:initialExpanded="false" />

            <!-- Section: Other -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/section_other"
                android:textAllCaps="true"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:letterSpacing="0.05" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/skland_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardTitle="@string/skland_sign_in"
                app:initialExpanded="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/image_button"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/view_miyoushe_ranking"
                app:icon="@drawable/ic_link_url" />

            <com.muxiao.Venus.common.CollapsibleCardView
                android:id="@+id/about_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardTitle="@string/about"
                app:initialExpanded="false" />

            <View
                android:id="@+id/bottom_padding_view"
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_bottom_fab" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
