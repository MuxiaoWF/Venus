<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Corner Shapes -->
    <style name="ShapeAppearance.Venus.Card" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_grouped_section</item>
    </style>

    <style name="ShapeAppearance.Venus.Card.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_inner_component</item>
    </style>

    <!-- Card: Grouped section container -->
    <style name="Widget.Venus.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">@color/divider_color</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Venus.Card</item>
    </style>

    <!-- Card.ListItem: Kept for compatibility, no longer primary style -->
    <style name="Widget.Venus.Card.ListItem" parent="Widget.Venus.Card">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="strokeWidth">0dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Venus.Card.Small</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- Toolbar: Apple large title style -->
    <style name="Widget.Venus.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="subtitleTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:background">@color/transparent</item>
        <item name="android:layout_marginTop">0dp</item>
    </style>

    <!-- Section Header: Uppercase muted label -->
    <style name="TextAppearance.Venus.SectionHeader" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">@dimen/text_section_header</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Grouped Section Background -->
    <style name="Widget.Venus.GroupedSection" parent="android:Widget">
        <item name="android:background">@drawable/bg_grouped_section</item>
        <item name="android:padding">@dimen/spacing_md</item>
    </style>
</resources>
